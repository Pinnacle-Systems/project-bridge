# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Prisma connection string for the bridge metadata database.
# Run `pnpm --filter @project-bridge/api db:migrate:deploy` after first setup.
DATABASE_URL="postgresql://bridge_user:bridge_pass@localhost:5432/bridge_db?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Admin API ────────────────────────────────────────────────────────────────
# All /bridge/* admin endpoints require this key in the x-admin-api-key header.
# Runtime /api/* endpoints do not use this key — they rely on the application's
# own permission layer (see PermissionChecker in runtime/permissions.ts).
ADMIN_API_KEY="change-me-before-use"

# ─── Oracle runtime connection ────────────────────────────────────────────────
# The server opens one persistent Oracle connection at startup for all runtime
# query and PL/SQL execution. Admin-plane inspection opens short-lived per-request
# connections using the credentials stored per ApiConnection record.
ORACLE_USER="BRIDGE_RUNTIME_USER"
ORACLE_PASSWORD="oracle_runtime_password"

# Choose ONE of the following connection styles:

# Option A — service name (most common for modern Oracle / RAC setups)
ORACLE_HOST="oracle.example.com"
ORACLE_PORT=1521
ORACLE_SERVICE_NAME="ORCL"

# Option B — SID (older single-instance databases)
# ORACLE_HOST="oracle.example.com"
# ORACLE_PORT=1521
# ORACLE_SID="ORCL"

# Option C — full TNS / Easy Connect Plus string (overrides HOST/PORT/SERVICE_NAME/SID)
# ORACLE_CONNECT_STRING="oracle.example.com:1521/ORCL"

# ─── Oracle driver mode ───────────────────────────────────────────────────────
# "thin"  — pure Node.js driver, no Oracle Client libraries required (default).
# "thick" — requires Oracle Instant Client or a full Oracle Client installation.
#            Required for Wallet/TLS connections, some older Oracle versions, and
#            advanced features (e.g. proxy authentication, certain LOB handling).
# ORACLE_DRIVER_MODE="thin"

# Path to Oracle Instant Client libraries (only needed in thick mode).
# ORACLE_CLIENT_LIB_DIR="/opt/oracle/instantclient_21_9"
